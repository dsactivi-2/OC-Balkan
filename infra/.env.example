# ============================================
# OpenClaw Balkan — Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to git!

# --- Domain ---
DOMAIN=example.com
# Additional domains (comma-separated for Certbot)
CERTBOT_DOMAINS=example.com,www.example.com

# --- Let's Encrypt ---
LETSENCRYPT_EMAIL=admin@example.com

# --- PostgreSQL ---
POSTGRES_USER=openclaw
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
POSTGRES_DB=openclaw

# --- Redis ---
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD_HERE

# --- OpenClaw ---
OPENCLAW_SECRET_KEY=CHANGE_ME_RANDOM_SECRET_64_CHARS
OPENCLAW_PORT=4173

# --- LLM API Keys ---
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# --- Viber Business API ---
VIBER_AUTH_TOKEN=
VIBER_BOT_NAME="OpenClaw Balkan"

# --- WhatsApp Business API (Meta) ---
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=

# --- Stripe (via DE/AT Entity) ---
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_live_...

# --- Backup ---
BACKUP_RETENTION_DAYS=30
BACKUP_PATH=/opt/openclaw/backups

# --- Monitoring ---
HEALTHCHECK_URL=https://hc-ping.com/YOUR-UUID-HERE
ALERT_EMAIL=admin@example.com

# --- Server ---
SERVER_TIMEZONE=Europe/Sarajevo
